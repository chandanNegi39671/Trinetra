# ── Copy this file to .env and fill in your values ──────────────────────────
# Command: copy .env.example .env   (Windows)
#          cp .env.example .env     (Linux/Mac)

# ── Google Safe Browsing ─────────────────────────────────────────────────────
# Get free key: https://console.cloud.google.com → APIs → Safe Browsing API
GOOGLE_SAFE_BROWSING_KEY=your_key_here

# ── Twilio WhatsApp Bot ──────────────────────────────────────────────────────
# Get free trial: https://www.twilio.com/try-twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ── CORS (comma-separated allowed origins for production) ────────────────────
ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# ── WhatsApp bot — URL of main API ──────────────────────────────────────────
TRINETRA_API_URL=http://localhost:5000

# ── Ports ────────────────────────────────────────────────────────────────────
PORT=5000
BOT_PORT=5001
